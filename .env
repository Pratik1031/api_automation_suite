# Environment: local | staging | prod
ENV=local

# Base URLs per environment
BASE_URL_LOCAL=https://jsonplaceholder.typicode.com
BASE_URL_STAGING=https://jsonplaceholder.typicode.com
BASE_URL_PROD=https://jsonplaceholder.typicode.com

# Auth (replace with real values per environment)
API_KEY=test-api-key-123
AUTH_TOKEN=Bearer test-token-abc

# Timeouts (seconds)
REQUEST_TIMEOUT=10
